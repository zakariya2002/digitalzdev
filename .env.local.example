VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Note : Les clés Twilio ne vont PAS dans le frontend.
# Elles sont configurées comme secrets Supabase Edge Functions :
# supabase secrets set TWILIO_ACCOUNT_SID=ACxxxx
# supabase secrets set TWILIO_AUTH_TOKEN=xxxx
# supabase secrets set TWILIO_API_KEY=SKxxxx
# supabase secrets set TWILIO_API_SECRET=xxxx
# supabase secrets set TWILIO_PHONE_NUMBER=+33xxxx
# supabase secrets set TWILIO_TWIML_APP_SID=APxxxx
